# ==========================================================
#  ZenithOX Environment Variables
#  Updated for Ollama local LLM backend
# ==========================================================

# Ollama server URL
# Default: http://localhost:11434 (local Ollama)
# Change to your remote server URL if running Ollama remotely
OLLAMA_BASE_URL=http://localhost:11434

# Tavily API key for web search (Researcher mode)
# Get your key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Flask secret key (auto-generated if not set)
FLASK_SECRET_KEY=

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
