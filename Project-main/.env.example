# ===== Zenith OX — environment variables =====
# Copy this file to ".env" and fill in real keys.

GROQ_API_KEY=gsk-your-groq-key-here
TAVILY_API_KEY=tvly-your-tavily-key-here

# Optional: a strong random string for Flask session cookies.
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Optional: Google OAuth credentials (leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
